<UserControl x:Class="SsmsResultsGrid.Views.ResultsViewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:vsui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:res="clr-namespace:SsmsResultsGrid.Resources"
             mc:Ignorable="d"
             Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
             Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             d:DesignHeight="460" d:DesignWidth="900"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!--  Theme-aware accent palette.  Keys resolve from the running VS shell (Light/Dark/Blue/High-Contrast)  -->
        <!--  by referencing the Color variants of EnvironmentColors and wrapping them in SolidColorBrushes  -->
        <!--  so we can reuse them (and, where needed, dial opacity down for subtle tints).  -->
        <SolidColorBrush x:Key="Accent.Border"
                         Color="{DynamicResource {x:Static vsui:EnvironmentColors.AccentBorderColorKey}}" />
        <SolidColorBrush x:Key="Accent.Medium"
                         Color="{DynamicResource {x:Static vsui:EnvironmentColors.AccentMediumColorKey}}" />
        <SolidColorBrush x:Key="Accent.Light"
                         Color="{DynamicResource {x:Static vsui:EnvironmentColors.AccentLightColorKey}}" />
        <SolidColorBrush x:Key="Accent.Pale"
                         Color="{DynamicResource {x:Static vsui:EnvironmentColors.AccentPaleColorKey}}" />

        <!--  Subtle row zebra tint: accent pale with reduced opacity.  -->
        <SolidColorBrush x:Key="Row.Zebra"
                         Color="{DynamicResource {x:Static vsui:EnvironmentColors.AccentPaleColorKey}}"
                         Opacity="0.35" />

        <!--  Highlight for matched substrings in filtered cells — accent-derived so it  -->
        <!--  tracks the active theme instead of a hardcoded hex value.  -->
        <SolidColorBrush x:Key="Match.Background"
                         Color="{DynamicResource {x:Static vsui:EnvironmentColors.AccentMediumColorKey}}"
                         Opacity="0.5" />
        <SolidColorBrush x:Key="Match.Foreground"
                         Color="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextColorKey}}" />

        <!--  Vector glyphs — all authored in a 16x16 viewport, no font dependency.  -->
        <Geometry x:Key="Icon.Refresh">M13.5,4 L13.5,7 L10.5,7 M13.5,7 A5.5,5.5 0 1 1 8,1.5</Geometry>
        <Geometry x:Key="Icon.Copy">M5.5,5.5 L11,5.5 L11,13 L5.5,13 Z M7,3.5 L12.5,3.5 L12.5,11</Geometry>
        <Geometry x:Key="Icon.Export">M8,2 L8,9 M5,6 L8,9 L11,6 M3,11 L13,11</Geometry>
        <Geometry x:Key="Icon.Clear">M4,4 L12,12 M12,4 L4,12</Geometry>
        <Geometry x:Key="Icon.Search">M2,6.5 A4.5,4.5 0 1 1 11,6.5 A4.5,4.5 0 1 1 2,6.5 Z M9.5,9.5 L13,13</Geometry>
        <Geometry x:Key="Icon.SortAsc">M3,9 L8,4 L13,9 Z</Geometry>
        <Geometry x:Key="Icon.SortDesc">M3,7 L13,7 L8,12 Z</Geometry>

        <!--  TextBox: flat, accent border on focus.  -->
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}" />
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ComboBoxBackgroundKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
            <Setter Property="CaretBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource Accent.Medium}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="0"
                                          Padding="{TemplateBinding Padding}"
                                          Background="Transparent"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent.Light}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent.Border}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Base flat button used by the toolbar.  -->
        <Style TargetType="Button" x:Key="FlatButton">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}" />
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="Cp"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              SnapsToDevicePixels="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Accent.Pale}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent.Light}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Accent.Light}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent.Border}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent.Border}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Default for any unstyled Button in this UserControl.  -->
        <Style TargetType="Button" BasedOn="{StaticResource FlatButton}" />

        <!--  Icon-only square button for the inline clear X. Uses a faint theme tint
              instead of full transparency so the glyph reads as clickable.  -->
        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="MinHeight" Value="20" />
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{DynamicResource Row.Zebra}" />
        </Style>

        <!--  ComboBox items share the flat palette.  -->
        <Style x:Key="FlatComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Accent.Pale}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Accent.Light}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource FlatComboBoxItem}" />

        <!--  ComboBox: flat background, chevron toggle, popup matches toolbar palette.  -->
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Padding" Value="10,3,6,3" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}" />
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ComboBoxBackgroundKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Grid.ColumnSpan="2"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="2"
                                                SnapsToDevicePixels="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="18" />
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1"
                                                      Width="9"
                                                      Height="5"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Data="M0,0 L4.5,4.5 L9,0 Z"
                                                      Fill="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
                                                      Opacity="0.75" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent.Light}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent.Border}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              TextBlock.Foreground="{TemplateBinding Foreground}" />
                            <Popup x:Name="Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Grid MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                      SnapsToDevicePixels="True">
                                    <Border Margin="0,1,0,0"
                                            Background="{DynamicResource {x:Static vsshell:VsBrushes.ComboBoxBackgroundKey}}"
                                            BorderBrush="{DynamicResource Accent.Light}"
                                            BorderThickness="1"
                                            SnapsToDevicePixels="True">
                                        <ScrollViewer>
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{DynamicResource Accent.Border}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  CheckBox: flat check.  -->
        <Style TargetType="CheckBox">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
            <Setter Property="Padding" Value="4,0,0,0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Border x:Name="Box"
                                    Width="14"
                                    Height="14"
                                    VerticalAlignment="Center"
                                    BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}"
                                    BorderThickness="1"
                                    Background="{DynamicResource {x:Static vsshell:VsBrushes.ComboBoxBackgroundKey}}"
                                    CornerRadius="2"
                                    SnapsToDevicePixels="True">
                                <Path x:Name="Check"
                                      Margin="2"
                                      Stretch="Uniform"
                                      Data="M0,5 L4,9 L10,1"
                                      Stroke="{DynamicResource Accent.Border}"
                                      StrokeThickness="1.6"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Accent.Border}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Accent.Light}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Accent.Border}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  DataGrid column headers: flat, sort indicator, accent on hover.  -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}" />
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
            <Setter Property="SeparatorBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Margin="{TemplateBinding Padding}"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="Center"
                                                      RecognizesAccessKey="True"
                                                      SnapsToDevicePixels="True" />
                                    <Path x:Name="SortArrow"
                                          Grid.Column="1"
                                          Width="9"
                                          Height="6"
                                          Margin="4,0,8,0"
                                          VerticalAlignment="Center"
                                          Fill="{DynamicResource Accent.Border}"
                                          Data="{StaticResource Icon.SortAsc}"
                                          Visibility="Collapsed" />
                                </Grid>
                            </Border>
                            <!--  Accent underline when sorted  -->
                            <Border x:Name="SortUnderline"
                                    Height="2"
                                    VerticalAlignment="Bottom"
                                    Background="{DynamicResource Accent.Border}"
                                    Visibility="Collapsed" />
                            <Thumb x:Name="PART_LeftHeaderGripper"
                                   Width="2"
                                   HorizontalAlignment="Left"
                                   Cursor="SizeWE">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                            <Thumb x:Name="PART_RightHeaderGripper"
                                   Width="2"
                                   HorizontalAlignment="Right"
                                   Cursor="SizeWE">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Accent.Pale}" />
                            </Trigger>
                            <Trigger Property="SortDirection" Value="Ascending">
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                                <Setter TargetName="SortArrow" Property="Data" Value="{StaticResource Icon.SortAsc}" />
                                <Setter TargetName="SortUnderline" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="SortDirection" Value="Descending">
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                                <Setter TargetName="SortArrow" Property="Data" Value="{StaticResource Icon.SortDesc}" />
                                <Setter TargetName="SortUnderline" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Row header: flat number column.  -->
        <Style TargetType="DataGridRowHeader">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Opacity" Value="0.72" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
        </Style>

        <!--  Row: subtle hover + accent selected state.  -->
        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{DynamicResource Row.Zebra}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Accent.Pale}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Accent.Light}" />
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  Cell: no dotted focus rect, accent selected bg.  -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              SnapsToDevicePixels="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Accent.Medium}" />
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Margin="0"
            BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}"
            BorderThickness="1"
            Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}">
        <DockPanel LastChildFill="True">

            <!--  TOOLBAR  -->
            <Border DockPanel.Dock="Top"
                    BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}"
                    BorderThickness="0,0,0,1"
                    Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
                    Padding="10,8">
                <DockPanel LastChildFill="True">

                    <!--  Title + capture status on the left  -->
                    <StackPanel DockPanel.Dock="Left"
                                VerticalAlignment="Center"
                                Margin="0,0,16,0">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="3"
                                       Height="14"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Fill="{DynamicResource Accent.Border}"
                                       RadiusX="1.5"
                                       RadiusY="1.5" />
                            <TextBlock FontWeight="SemiBold"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Text="{x:Static res:Strings.ViewTitle}" />
                        </StackPanel>
                        <TextBlock Margin="11,2,0,0"
                                   FontSize="11"
                                   Opacity="0.72"
                                   Text="{Binding StatusText}" />
                    </StackPanel>

                    <!--  Filter group pinned to the right  -->
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <ComboBox x:Name="ResultSetSelector"
                                  MinWidth="140"
                                  Margin="0,0,8,0"
                                  ItemsSource="{Binding ResultSets}"
                                  SelectedItem="{Binding SelectedResultSet, Mode=TwoWay}"
                                  DisplayMemberPath="Title"
                                  Visibility="{Binding HasMultipleResultSets, Converter={StaticResource BoolToVis}}"
                                  ToolTip="{x:Static res:Strings.ResultSetSelectorTooltip}" />

                        <ComboBox x:Name="FilterModeBox"
                                  Width="112"
                                  Margin="0,0,8,0"
                                  SelectedIndex="{Binding SelectedResultSet.FilterModeIndex, Mode=TwoWay}"
                                  ToolTip="{x:Static res:Strings.FilterModeTooltip}">
                            <ComboBoxItem Content="{x:Static res:Strings.FilterModeContains}" />
                            <ComboBoxItem Content="{x:Static res:Strings.FilterModeStartsWith}" />
                            <ComboBoxItem Content="{x:Static res:Strings.FilterModeExact}" />
                        </ComboBox>

                        <CheckBox Margin="0,0,12,0"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding SelectedResultSet.FilterCaseSensitive, Mode=TwoWay}"
                                  ToolTip="{x:Static res:Strings.MatchCaseTooltip}"
                                  Content="{x:Static res:Strings.MatchCase}" />

                        <!--  Filter box with search glyph + inline clear.  -->
                        <Grid Width="280" VerticalAlignment="Center">
                            <TextBox x:Name="FilterBox"
                                     Padding="27,4,26,4"
                                     Text="{Binding SelectedResultSet.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{x:Static res:Strings.FilterBoxTooltip}" />
                            <Path Width="14"
                                  Height="14"
                                  Margin="8,0,0,0"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  Data="{StaticResource Icon.Search}"
                                  Stroke="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
                                  StrokeThickness="1.2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Opacity="0.55"
                                  IsHitTestVisible="False" />
                            <TextBlock IsHitTestVisible="False"
                                       Margin="28,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
                                       Opacity="0.55"
                                       Text="{x:Static res:Strings.FilterPlaceholder}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=FilterBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button x:Name="ClearFilterButton"
                                    Margin="0,0,4,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
                                    Click="ClearFilterButton_Click"
                                    ToolTip="{x:Static res:Strings.ClearFilterTooltip}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=FilterBox}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Path Width="11"
                                      Height="11"
                                      Stretch="Uniform"
                                      Data="{StaticResource Icon.Clear}"
                                      Stroke="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                            </Button>
                        </Grid>
                    </StackPanel>

                    <!--  Action buttons fill the middle (right-aligned)  -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0">
                        <Button Margin="0,0,6,0"
                                Command="{Binding RefreshCommand}"
                                ToolTip="{x:Static res:Strings.RefreshTooltip}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Width="14"
                                      Height="14"
                                      Margin="0,0,7,0"
                                      VerticalAlignment="Center"
                                      Data="{StaticResource Icon.Refresh}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.3"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                                <TextBlock Text="{x:Static res:Strings.Refresh}"
                                           VerticalAlignment="Center"
                                           FontSize="12" />
                            </StackPanel>
                        </Button>

                        <Button Margin="0,0,6,0"
                                Click="CopySelectedButton_Click"
                                ToolTip="{x:Static res:Strings.CopyTooltip}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Width="14"
                                      Height="14"
                                      Margin="0,0,7,0"
                                      VerticalAlignment="Center"
                                      Data="{StaticResource Icon.Copy}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.3"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                                <TextBlock Text="{x:Static res:Strings.Copy}"
                                           VerticalAlignment="Center"
                                           FontSize="12" />
                            </StackPanel>
                        </Button>

                        <Button Click="ExportCsvButton_Click"
                                ToolTip="{x:Static res:Strings.ExportCsvTooltip}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Width="14"
                                      Height="14"
                                      Margin="0,0,7,0"
                                      VerticalAlignment="Center"
                                      Data="{StaticResource Icon.Export}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.3"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                                <TextBlock Text="{x:Static res:Strings.ExportCsv}"
                                           VerticalAlignment="Center"
                                           FontSize="12" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!--  Capture progress: thin indeterminate strip under the toolbar.  -->
            <ProgressBar DockPanel.Dock="Top"
                         Height="3"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{DynamicResource Accent.Border}"
                         IsIndeterminate="{Binding IsCapturing}"
                         Visibility="{Binding IsCapturing, Converter={StaticResource BoolToVis}}" />

            <!--  STATUS BAR  -->
            <Border DockPanel.Dock="Bottom"
                    Margin="0"
                    Padding="10,6"
                    BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}"
                    BorderThickness="0,1,0,0"
                    Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Opacity="0.75"
                               Text="{Binding SelectedResultSet.RowSummaryText}" />
                    <TextBlock Grid.Column="1"
                               Margin="16,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Opacity="0.75"
                               Text="{Binding SelectedResultSet.FilterLatencyText}" />
                    <TextBlock Grid.Column="2"
                               Margin="16,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Opacity="0.75"
                               Text="{Binding LastUpdatedText}" />
                </Grid>
            </Border>

            <!--  DATA GRID (columns generated in code-behind from the view model)  -->
            <DataGrid x:Name="ResultsGrid"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ItemsSource="{Binding SelectedResultSet.VisibleRows}"
                      LoadingRow="ResultsGrid_LoadingRow"
                      Sorting="ResultsGrid_Sorting"
                      AutoGenerateColumns="False"
                      AlternationCount="2"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="All"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}"
                      VerticalGridLinesBrush="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}"
                      RowBackground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
                      Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
                      Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
                      BorderThickness="0"
                      RowHeaderWidth="52"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.ScrollUnit="Pixel"
                      SelectionUnit="CellOrRowHeader"
                      ClipboardCopyMode="IncludeHeader">
                <DataGrid.Resources>
                    <!--  Top-left corner "select all" button: painted like the column header row.  -->
                    <Style TargetType="{x:Type Button}"
                           x:Key="{ComponentResourceKey TypeInTargetAssembly={x:Type DataGrid}, ResourceId=DataGridSelectAllButtonStyle}">
                        <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}" />
                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                        <Setter Property="Cursor" Value="Arrow" />
                        <Setter Property="Focusable" Value="False" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            SnapsToDevicePixels="True" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.Resources>
            </DataGrid>
        </DockPanel>
    </Border>
</UserControl>
